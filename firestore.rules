rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function canOpenAdmin() {
      return signedIn() && myRole() in ['admin', 'manager'];
    }
    function canPublish() {
      return signedIn() && myRole() in ['admin', 'manager', 'district_leader', 'team_leader'];
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if signedIn() && (
        request.auth.uid == userId ||
        canOpenAdmin()
      );
    }
    match /crews/{crewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /battles/{battleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /customQuizzes/{quizId} {
      allow read: if true;
      allow write: if canOpenAdmin();
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if canOpenAdmin();
    }
    match /events/{eventId} {
      allow read: if true;
      allow write: if canPublish();
    }
    match /event_participants/{participantId} {
      allow read: if canOpenAdmin();
      allow create: if signedIn();
      allow update: if signedIn();
    }
    match /mission_exam_submissions/{submissionId} {
      allow get: if signedIn();
      allow list: if canOpenAdmin();
      allow create, update: if signedIn();
    }
    match /push_queue/{pushId} {
      allow read, write: if canPublish();
    }
    match /logs/{logId} {
      allow read: if canOpenAdmin();
      allow write: if canPublish();
    }
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if canPublish();
    }
    match /notifications/{notificationId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.keys().hasAny(['targetUsers']) && resource.data.targetUsers.hasAny([request.auth.uid])) ||
        (resource.data.keys().hasAny(['targetGroups']) && resource.data.targetGroups.hasAny([myRole()])) ||
        canOpenAdmin()
      );
      allow create: if signedIn();
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        canPublish()
      );
      allow delete: if canPublish();
    }
    match /password_resets/{resetId} {
      allow create: if true;
      allow read: if canOpenAdmin();
    }
  }
}
